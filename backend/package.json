{
  "name": "signal-api",
  "version": "0.1.0",
  "private": true,
  "description": "Signal — lightweight security scanner API",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node scripts/migrate.js",
    "auth:migrate": "npx @better-auth/cli migrate --config ./src/auth.js --yes"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "better-auth": "^1.5.5",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.12.0",
    "openai": "^6.32.0",
    "uuid": "^13.0.0"
  }
}
