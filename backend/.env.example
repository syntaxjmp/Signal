NODE_ENV=development
# Use 4000 in dev when Next.js runs on 3000 (see frontend rewrites).
PORT=4000

# MySQL (shared by Signal app + Better Auth tables)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=signal
MYSQL_PASSWORD=
MYSQL_DATABASE=Signal

DB_AUTO_MIGRATE=0

# Better Auth — required
# Generate: openssl rand -base64 32   (must be >= 32 characters)
BETTER_AUTH_SECRET=dI2ghvHZOGxLNOVQbX2V3aAvYbyXnLqKWFtUg4Vb5Vs=

# URL the **browser** uses for auth (usually the Next.js origin). No trailing slash.
# With Next rewrites, this is http://localhost:3000 even though Express listens on PORT.
BETTER_AUTH_URL=http://localhost:3000

# Origins allowed to use cookies / CSRF with Better Auth (your Next app URL(s)).
# Comma-separated Next.js origin(s). If unset in development, defaults include :3000 and :3001.
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Optional: also used for CORS when set (can align with BETTER_AUTH_TRUSTED_ORIGINS)
# CORS_ORIGINS=http://localhost:3001

# AI scanner configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional for higher GitHub API limits/private repos
# GITHUB_TOKEN=
